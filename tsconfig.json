{
  "compilerOptions": {
    // ⭐ Essencial - Define o projeto
    "target": "esnext",
    "module": "nodenext",
    "lib": ["esnext"],
    "rootDir": "./src",
    "outDir": "./dist",

    // 🔒 Segurança - Força TypeScript correto
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    // 📦 Node.js + imports/exports
    "types": ["node"],
    "verbatimModuleSyntax": true,

    // 🐛 Developer experience
    "sourceMap": true,
    "skipLibCheck": true
  }
}
